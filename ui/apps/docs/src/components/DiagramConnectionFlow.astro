---
import {
  CommandLineIcon,
  CpuChipIcon,
  GlobeAltIcon,
  LockClosedIcon,
} from "@heroicons/react/24/outline";
---

<div
  class="flow-container"
  role="img"
  aria-label="Diagram of an SSH session path: the SSH client connects to the Gateway, which routes to the SSH Service, which reaches the Agent over its reverse tunnel, and the Agent execs a shell on the device."
>
  <div class="flow-pipeline">
    <!-- SSH Client -->
    <div class="flow-step">
      <div class="flow-node">
        <CommandLineIcon className="flow-icon" />
      </div>
      <span class="flow-label">SSH Client</span>
    </div>

    <!-- Arrow -->
    <div class="flow-connector">
      <div class="flow-line"></div>
      <span class="flow-conn-label">SSH</span>
      <svg class="flow-chevron" viewBox="0 0 8 12" fill="currentColor"><path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <!-- Gateway -->
    <div class="flow-step">
      <div class="flow-node flow-node--accent">
        <GlobeAltIcon className="flow-icon" />
      </div>
      <span class="flow-label">Gateway</span>
    </div>

    <!-- Arrow -->
    <div class="flow-connector">
      <div class="flow-line"></div>
      <span class="flow-conn-label">route</span>
      <svg class="flow-chevron" viewBox="0 0 8 12" fill="currentColor"><path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <!-- SSH Service -->
    <div class="flow-step">
      <div class="flow-node flow-node--accent">
        <LockClosedIcon className="flow-icon" />
      </div>
      <span class="flow-label">SSH Service</span>
    </div>

    <!-- Arrow -->
    <div class="flow-connector">
      <div class="flow-line flow-line--dashed"></div>
      <span class="flow-conn-label">reverse tunnel</span>
      <svg class="flow-chevron" viewBox="0 0 8 12" fill="currentColor"><path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <!-- Agent -->
    <div class="flow-step">
      <div class="flow-node flow-node--accent">
        <CpuChipIcon className="flow-icon" />
      </div>
      <span class="flow-label">Agent</span>
    </div>

    <!-- Arrow -->
    <div class="flow-connector">
      <div class="flow-line flow-line--green"></div>
      <span class="flow-conn-label">exec</span>
      <svg class="flow-chevron flow-chevron--green" viewBox="0 0 8 12" fill="currentColor"><path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>

    <!-- Shell -->
    <div class="flow-step">
      <div class="flow-node flow-node--green">
        <CommandLineIcon className="flow-icon" />
      </div>
      <span class="flow-label flow-label--green">Shell</span>
    </div>
  </div>
</div>

<style lang="postcss">
  .flow-container {
    background: theme('colors.surface');
    border: 1px solid theme('colors.border');
    border-radius: 12px;
    padding: 28px 24px;
    margin: 12px 0 24px;
    overflow-x: auto;
  }

  .flow-pipeline {
    display: flex;
    align-items: flex-start;
    gap: 0;
    min-width: 560px;
  }

  .flow-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .flow-node {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: theme('colors.card');
    border: 1px solid theme('colors.border');
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .flow-node--accent {
    border-color: rgba(102, 122, 204, 0.3);
    background: rgba(102, 122, 204, 0.06);
  }

  .flow-node--green {
    border-color: rgba(130, 165, 104, 0.3);
    background: rgba(130, 165, 104, 0.06);
  }

  .flow-icon {
    width: 22px;
    height: 22px;
    color: theme('colors.text-secondary');
  }

  .flow-node--accent .flow-icon {
    color: theme('colors.primary.DEFAULT');
  }

  .flow-node--green .flow-icon {
    color: theme('colors.accent.green');
  }

  .flow-label {
    font-size: 11px;
    font-weight: 500;
    color: theme('colors.text-secondary');
    white-space: nowrap;
  }

  .flow-label--green {
    color: theme('colors.accent.green');
  }

  .flow-connector {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 48px;
    position: relative;
    padding-top: 10px;
    gap: 0;
  }

  .flow-line {
    flex: 1;
    height: 1px;
    background: rgba(102, 122, 204, 0.25);
  }

  .flow-line--dashed {
    background: none;
    border-top: 1px dashed rgba(102, 122, 204, 0.25);
  }

  .flow-line--green {
    background: rgba(130, 165, 104, 0.25);
  }

  .flow-chevron {
    width: 8px;
    height: 12px;
    color: rgba(102, 122, 204, 0.4);
    flex-shrink: 0;
  }

  .flow-chevron--green {
    color: rgba(130, 165, 104, 0.4);
  }

  .flow-conn-label {
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: theme('colors.text-muted');
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .flow-container { padding: 20px 16px; }
  }
</style>
