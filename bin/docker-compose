#!/bin/sh
set -eu

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd -P)
cd "$SCRIPT_DIR/.."

env_override=${ENV_OVERRIDE:-./.env.override}
cloud_dir=${CLOUD_DIR:-../cloud}

# Peek EDITION first using only the shellhub-side files; the result
# decides whether env_var() should also source cloud/.env. This mirrors
# COMPOSE_ENV_FILES (which gates cloud/.env on edition != community) so the
# wrapper's view of every other flag matches what containers will see.
SHELLHUB_EDITION=$(
    . ./.env 2>/dev/null
    [ -f "$env_override" ] && . "$env_override"
    eval "printf '%s' \"\${SHELLHUB_EDITION:-community}\""
)

# Normalize: lowercase, trim whitespace.
SHELLHUB_EDITION=$(printf '%s' "$SHELLHUB_EDITION" | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')

case "$SHELLHUB_EDITION" in
    community|enterprise|cloud) ;;
    *)
        echo "🚫 ERROR: invalid SHELLHUB_EDITION '$SHELLHUB_EDITION': must be community, enterprise, or cloud." >&2
        exit 1
        ;;
esac

# Read a single shellhub flag in a subshell, without polluting the wrapper's
# env. Sources the same files Compose loads via COMPOSE_ENV_FILES.
env_var() {
    var=$1; default=$2
    edition=$SHELLHUB_EDITION
    (
        . ./.env 2>/dev/null
        [ "$edition" != "community" ] && [ -f "$cloud_dir/.env" ] \
            && . "$cloud_dir/.env"
        [ -f "$env_override" ] && . "$env_override"
        eval "printf '%s' \"\${${var}:-${default}}\""
    )
}

SHELLHUB_ENV=$(env_var SHELLHUB_ENV production)
SHELLHUB_AUTO_SSL=$(env_var SHELLHUB_AUTO_SSL false)
SHELLHUB_DATABASE=$(env_var SHELLHUB_DATABASE postgres)
SHELLHUB_BILLING=$(env_var SHELLHUB_BILLING "")

# COMPOSE_ENV_FILES — last file wins. Order chosen so that:
#   - CE defaults are the base
#   - enterprise defaults augment when edition is enterprise or cloud
#   - cloud defaults augment when cloud/ is loaded (gate: edition != community)
#   - shellhub/.env.override is ALWAYS LAST: user customizations win over
#     every preceding default. There is no cloud/.env.override anymore —
#     dev customizations live in shellhub/.env.override only.
COMPOSE_ENV_FILES="./.env"
[ "$SHELLHUB_EDITION" != "community" ] && [ -f ./.env.enterprise ] \
    && COMPOSE_ENV_FILES="$COMPOSE_ENV_FILES,./.env.enterprise"
[ "$SHELLHUB_EDITION" != "community" ] && [ -f "$cloud_dir/.env" ] \
    && COMPOSE_ENV_FILES="$COMPOSE_ENV_FILES,$cloud_dir/.env"
[ -f "$env_override" ] && COMPOSE_ENV_FILES="$COMPOSE_ENV_FILES,$env_override"
export COMPOSE_ENV_FILES

COMPOSE_FILE="docker-compose.yml"
[ "$SHELLHUB_AUTO_SSL" = "true" ] && COMPOSE_FILE="${COMPOSE_FILE}:docker-compose.autossl.yml"
[ "$SHELLHUB_ENV" = "development" ] && COMPOSE_FILE="${COMPOSE_FILE}:docker-compose.dev.yml:docker-compose.agent.yml"
[ "$SHELLHUB_EDITION" != "community" ] && [ "$SHELLHUB_ENV" != "development" ] && COMPOSE_FILE="${COMPOSE_FILE}:docker-compose.enterprise.yml"
[ "$SHELLHUB_EDITION" != "community" ] && [ "$SHELLHUB_ENV" = "development" ] && [ -f "$cloud_dir/docker-compose.enterprise.dev.yml" ] && COMPOSE_FILE="${COMPOSE_FILE}:$cloud_dir/docker-compose.enterprise.dev.yml"
[ "$SHELLHUB_EDITION" = "cloud" ] && [ -f "$cloud_dir/docker-compose.yml" ] && COMPOSE_FILE="${COMPOSE_FILE}:$cloud_dir/docker-compose.yml"

# Activate the profile matching the configured billing provider.
[ -n "$SHELLHUB_BILLING" ] && export COMPOSE_PROFILES="$SHELLHUB_BILLING"

case "$SHELLHUB_DATABASE" in
    postgres)
        COMPOSE_FILE="${COMPOSE_FILE}:docker-compose.postgres.yml"
        ;;
    *)
        echo "⚠️ WARNING: Unknown SHELLHUB_DATABASE '$SHELLHUB_DATABASE'. Defaulting to postgres." >&2
        SHELLHUB_DATABASE="postgres"
        COMPOSE_FILE="${COMPOSE_FILE}:docker-compose.postgres.yml"
        ;;
esac

# docker-compose.override.yml must come after the database overlays so user
# customizations win (Compose applies later files with higher precedence).
[ -f docker-compose.override.yml ] && COMPOSE_FILE="${COMPOSE_FILE}:docker-compose.override.yml"
[ -f "${EXTRA_COMPOSE_FILE:-}" ] && COMPOSE_FILE="${COMPOSE_FILE}:${EXTRA_COMPOSE_FILE}"
export COMPOSE_FILE

exec docker compose "$@"
